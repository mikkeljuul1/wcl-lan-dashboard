# Warcraft Logs API credentials
# Create a client at https://www.warcraftlogs.com/api/clients/
WCL_CLIENT_ID=your_client_id_here
WCL_CLIENT_SECRET=your_client_secret_here

# Optional: pre-populate a report code so the dashboard starts with it
# (This is the code from the report URL, e.g. ba8GyNv4nCKqgt7V)
WCL_REPORT_CODE=

# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=8080
